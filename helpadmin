from django.contrib import admin
from .models import HelpDetail

@admin.register(HelpDetail)
class HelpDetailAdmin(admin.ModelAdmin):
    list_display = ("name", "number", "issue", "created_at")   # columns shown in admin list
    search_fields = ("name", "number", "issue")                # enable search by these fields
    list_filter = ("created_at",)                              # filter sidebar by date
